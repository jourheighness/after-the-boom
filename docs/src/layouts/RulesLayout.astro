---
import Sidebar from '../components/Sidebar.astro';
import Search from '../components/Search.astro';
import Comments from '../components/Comments.astro';
import Editor from '../components/Editor.astro';
import '../styles/global.css';

interface TocEntry {
  level: number;
  id: string;
  title: string;
}
interface SectionGroup {
  source: string;
  color: string;
  toc: TocEntry[];
}
interface Props {
  sections: SectionGroup[];
  currentTab?: 'rules' | 'campaigns' | 'dm-screen' | 'research';
}
const { sections, currentTab = 'rules' } = Astro.props;
const showComments = !import.meta.env.PROD;
const showEditor = !import.meta.env.PROD;
const showDmScreen = !import.meta.env.PROD;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MONDAS Rules Reader</title>
</head>
<body>
  <div class="header">
    <button class="hamburger" id="hamburgerBtn">&#9776;</button>
    <nav class="tab-nav">
      <a href={`${base}/`} class={currentTab === 'rules' ? 'active' : ''}>Rules</a>
      <a href={`${base}/campaigns`} class={currentTab === 'campaigns' ? 'active' : ''}>Campaigns</a>
      <a href={`${base}/research`} class={currentTab === 'research' ? 'active' : ''}>Research</a>
      {showDmScreen && (
        <a href={`${base}/dm-screen`} class={currentTab === 'dm-screen' ? 'active' : ''}>DM Screen</a>
      )}
    </nav>
    <Search />
  </div>

  <Sidebar sections={sections} />

  <main class="main" id="main">
    <slot />
  </main>

  {showEditor && <Editor />}

  <script>
    // --- Sidebar toggle (mobile) ---
    document.getElementById('hamburgerBtn')?.addEventListener('click', () => {
      document.getElementById('sidebar')?.classList.toggle('open');
    });
    document.getElementById('main')?.addEventListener('click', () => {
      document.getElementById('sidebar')?.classList.remove('open');
    });

    // --- Scroll spy (position-based) ---
    // Matches sidebar links to content headings by position within data-source groups.
    // No dependency on heading IDs — immune to ProseMirror DOM node recycling.
    const sidebarEl = document.getElementById('sidebar');
    let _pointerInSidebar = false;
    sidebarEl?.addEventListener('pointerenter', () => _pointerInSidebar = true);
    sidebarEl?.addEventListener('pointerleave', () => _pointerInSidebar = false);

    let currentActive: Element | null = null;
    let spyRaf: number | null = null;
    let userHasScrolled = false;
    let cachedPairs: Array<[Element, Element]> | null = null;

    /**
     * Build heading↔link pairs by matching content sections to sidebar groups
     * via data-source, then matching headings to links by document order.
     * Cached — invalidated on sidebar DOM mutation.
     */
    function getHeadingLinkPairs(): Array<[Element, Element]> {
      if (cachedPairs) {
        // Quick staleness check: first heading still in DOM
        if (cachedPairs.length === 0 || cachedPairs[0][0].isConnected) return cachedPairs;
        cachedPairs = null;
      }

      const pairs: Array<[Element, Element]> = [];
      if (!sidebarEl) return (cachedPairs = pairs);

      for (const group of sidebarEl.querySelectorAll('.nav-group')) {
        const source = group.getAttribute('data-source');
        if (!source) continue;
        const section = document.querySelector(`.file-section[data-source="${source}"]`);
        if (!section) continue;

        const pm = section.querySelector('.ProseMirror');
        const container = pm || section;

        const titleLink = group.querySelector('a.nav-source');
        const navLinks = group.querySelectorAll('.nav-link');

        let subIdx = 0;
        for (const h of container.querySelectorAll('h1, h2, h3')) {
          const level = parseInt(h.tagName[1]);
          if (level === 1) {
            if (titleLink) pairs.push([h, titleLink]);
          } else {
            if (subIdx < navLinks.length) {
              pairs.push([h, navLinks[subIdx]]);
              subIdx++;
            }
          }
        }
      }

      return (cachedPairs = pairs);
    }

    function updateScrollSpy() {
      const threshold = 80;
      let best: Element | null = null;

      for (const [heading, link] of getHeadingLinkPairs()) {
        const rect = heading.getBoundingClientRect();
        if (rect.top <= threshold) best = link;
      }

      if (best && best !== currentActive) {
        currentActive?.classList.remove('active');
        best.classList.add('active');
        currentActive = best;

        if (userHasScrolled && sidebarEl && !_pointerInSidebar) {
          const rect = best.getBoundingClientRect();
          const sidebarRect = sidebarEl.getBoundingClientRect();
          if (rect.top < sidebarRect.top || rect.bottom > sidebarRect.bottom) {
            best.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
          }
        }
      }
    }

    window.addEventListener('scroll', () => {
      userHasScrolled = true;
      if (spyRaf) cancelAnimationFrame(spyRaf);
      spyRaf = requestAnimationFrame(updateScrollSpy);
    }, { passive: true });

    // Click-to-scroll: position-based lookup, doesn't rely on heading IDs
    sidebarEl?.addEventListener('click', (e) => {
      const link = (e.target as Element).closest('a.nav-source, a.nav-link');
      if (!link) return;

      e.preventDefault();

      for (const [heading, sidebarLink] of getHeadingLinkPairs()) {
        if (sidebarLink === link) {
          heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
          if (heading.id) history.replaceState(null, '', `#${heading.id}`);
          return;
        }
      }
    });

    // Watch for sidebar DOM changes (editor rebuilds it) → invalidate cache, re-run spy
    if (sidebarEl) {
      let sidebarTimer: ReturnType<typeof setTimeout> | null = null;
      const smo = new MutationObserver(() => {
        cachedPairs = null;
        if (sidebarTimer) clearTimeout(sidebarTimer);
        sidebarTimer = setTimeout(updateScrollSpy, 200);
      });
      smo.observe(sidebarEl, { childList: true, subtree: true });
    }

    // Initial activation after hydration
    setTimeout(updateScrollSpy, 300);

    // --- Escape closes sidebar on mobile ---
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.getElementById('sidebar')?.classList.remove('open');
      }
    });
  </script>
</body>
</html>
