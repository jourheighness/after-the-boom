---
import Sidebar from '../components/Sidebar.astro';
import Search from '../components/Search.astro';
import Comments from '../components/Comments.astro';
import Editor from '../components/Editor.astro';
import '../styles/global.css';

interface TocEntry {
  level: number;
  id: string;
  title: string;
}
interface SectionGroup {
  source: string;
  color: string;
  toc: TocEntry[];
}
interface Props {
  sections: SectionGroup[];
  currentTab?: 'rules' | 'campaigns' | 'dm-screen' | 'research';
}
const { sections, currentTab = 'rules' } = Astro.props;
const showComments = !import.meta.env.PROD;
const showEditor = !import.meta.env.PROD;
const showDmScreen = !import.meta.env.PROD;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>MONDAS Rules Reader</title>
</head>
<body>
  <div class="header">
    <button class="hamburger" id="hamburgerBtn">&#9776;</button>
    <nav class="tab-nav">
      <a href={`${base}/`} class={currentTab === 'rules' ? 'active' : ''}>Rules</a>
      <a href={`${base}/campaigns`} class={currentTab === 'campaigns' ? 'active' : ''}>Campaigns</a>
      <a href={`${base}/research`} class={currentTab === 'research' ? 'active' : ''}>Research</a>
      {showDmScreen && (
        <a href={`${base}/dm-screen`} class={currentTab === 'dm-screen' ? 'active' : ''}>DM Screen</a>
      )}
    </nav>
    <Search />
  </div>

  <Sidebar sections={sections} />

  <main class="main" id="main">
    <slot />
  </main>

  {showEditor && <Editor />}

  <script>
    // --- Sidebar toggle (mobile) ---
    document.getElementById('hamburgerBtn')?.addEventListener('click', () => {
      document.getElementById('sidebar')?.classList.toggle('open');
    });
    document.getElementById('main')?.addEventListener('click', () => {
      document.getElementById('sidebar')?.classList.remove('open');
    });

    // --- Scroll spy (IntersectionObserver) ---
    // Matches sidebar links to content headings by position within data-source groups.
    // No dependency on heading IDs — immune to ProseMirror DOM node recycling.
    // IntersectionObserver fires only when headings cross the threshold — no per-frame work.
    const THRESHOLD = 80;
    const sidebarEl = document.getElementById('sidebar');
    let currentActive: Element | null = null;
    let userHasScrolled = false;
    let _pointerInSidebar = false;

    sidebarEl?.addEventListener('pointerenter', () => (_pointerInSidebar = true));
    sidebarEl?.addEventListener('pointerleave', () => (_pointerInSidebar = false));

    /** Build heading↔link pairs fresh each time (no cache to go stale). */
    function buildPairs(): Array<[Element, Element]> {
      const pairs: Array<[Element, Element]> = [];
      if (!sidebarEl) return pairs;

      for (const group of sidebarEl.querySelectorAll('.nav-group')) {
        const source = group.getAttribute('data-source');
        if (!source) continue;
        const section = document.querySelector(`.file-section[data-source="${source}"]`);
        if (!section) continue;

        const container = section.querySelector('.ProseMirror') || section;
        const titleLink = group.querySelector('a.nav-source');
        const navLinks = group.querySelectorAll('.nav-link');

        let subIdx = 0;
        for (const h of container.querySelectorAll('h1, h2, h3')) {
          const level = parseInt(h.tagName[1]);
          if (level === 1) {
            if (titleLink) pairs.push([h, titleLink]);
          } else if (subIdx < navLinks.length) {
            pairs.push([h, navLinks[subIdx]]);
            subIdx++;
          }
        }
      }
      return pairs;
    }

    function activateLink(link: Element) {
      if (link === currentActive) return;
      currentActive?.classList.remove('active');
      link.classList.add('active');
      currentActive = link;

      if (userHasScrolled && sidebarEl && !_pointerInSidebar) {
        const rect = link.getBoundingClientRect();
        const sr = sidebarEl.getBoundingClientRect();
        if (rect.top < sr.top || rect.bottom > sr.bottom) {
          link.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        }
      }
    }

    function syncSpy() {
      let best: Element | null = null;
      for (const [heading, link] of buildPairs()) {
        if (heading.getBoundingClientRect().top <= THRESHOLD) best = link;
      }
      if (best) activateLink(best);
    }

    // --- IntersectionObserver: fires when any heading crosses the threshold line ---
    let headingObserver: IntersectionObserver | null = null;

    function observeHeadings() {
      headingObserver?.disconnect();
      headingObserver = new IntersectionObserver(syncSpy, {
        rootMargin: `-${THRESHOLD}px 0px 0px 0px`,
        threshold: [0, 1],
      });
      for (const [heading] of buildPairs()) {
        headingObserver.observe(heading);
      }
    }

    // --- Re-observe when sidebar rebuilds (editor syncs TOC) ---
    let rebuildTimer: ReturnType<typeof setTimeout>;
    if (sidebarEl) {
      new MutationObserver(() => {
        clearTimeout(rebuildTimer);
        rebuildTimer = setTimeout(() => { observeHeadings(); syncSpy(); }, 150);
      }).observe(sidebarEl, { childList: true, subtree: true });
    }

    // --- Scroll: track interaction + safety-net sync after scrolling stops ---
    let scrollTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('scroll', () => {
      userHasScrolled = true;
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(syncSpy, 100);
    }, { passive: true });

    // --- Click-to-scroll ---
    sidebarEl?.addEventListener('click', (e) => {
      const link = (e.target as Element).closest('a.nav-source, a.nav-link');
      if (!link) return;
      e.preventDefault();

      for (const [heading, sidebarLink] of buildPairs()) {
        if (sidebarLink === link) {
          heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
          if (heading.id) history.replaceState(null, '', `#${heading.id}`);
          return;
        }
      }
    });

    // --- Init ---
    observeHeadings();
    setTimeout(syncSpy, 300);

    // --- Escape closes sidebar on mobile ---
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.getElementById('sidebar')?.classList.remove('open');
      }
    });
  </script>
</body>
</html>
