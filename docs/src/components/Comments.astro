<!--
  Comment system: select text to annotate, SSE live sync with SQLite backend.
  Note: innerHTML usage below is safe because all user-supplied strings are escaped
  via escHtml() (which uses textContent assignment) before insertion into templates.
-->
<div class="comments-panel" id="commentsPanel"></div>
<button class="comment-float-btn" id="commentFloatBtn">+ Comment</button>
<div class="comment-popover" id="commentPopover"></div>

<script>
const STORAGE_KEY = 'mondas-reader-comments';
const IS_DEV = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';

type CommentCategory = 'note' | 'copy' | 'clarify' | 'design' | 'bug' | 'todo';
const CATEGORIES: { key: CommentCategory; label: string; placeholder: string }[] = [
  { key: 'note', label: 'Note', placeholder: 'Your comment...' },
  { key: 'copy', label: 'Copy', placeholder: 'What should this say?' },
  { key: 'clarify', label: 'Clarify', placeholder: "What's unclear?" },
  { key: 'design', label: 'Design', placeholder: 'Design question...' },
  { key: 'bug', label: 'Bug', placeholder: "What's wrong?" },
  { key: 'todo', label: 'Todo', placeholder: 'What needs doing?' },
];

interface Comment {
  id: string;
  selectedText: string;
  contextBefore: string;
  contextAfter: string;
  comment: string;
  category?: CommentCategory;
  sectionId: string;
  sourceFile: string;
  filePath?: string;
  nearestHeadingLine?: number;
  sourceLine?: number;
  paragraphIndex?: number;
  status: 'open' | 'resolved' | 'dismissed';
  resolution: string | null;
  resolvedText?: string;
  createdAt: string;
  resolvedAt: string | null;
  _orphaned?: boolean;
  _diffText?: string;
}

let comments: Comment[] = [];
let pendingSelection: {
  text: string;
  contextBefore: string;
  contextAfter: string;
  sectionId: string;
  sourceFile: string;
  headingLine?: number;
  sourceLine?: number;
  paragraphIndex?: number;
  range: Range;
  rect: DOMRect;
} | null = null;

// --- Cached element refs ---
const $popover = document.getElementById('commentPopover')!;
const $floatBtn = document.getElementById('commentFloatBtn')!;
const $panel = document.getElementById('commentsPanel')!;

// --- Escaping (all user content passes through this before innerHTML) ---
function escHtml(str: string): string {
  const d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}

function positionPopover(popover: HTMLElement, anchorRect: DOMRect) {
  popover.style.display = 'block';
  let left = anchorRect.left + window.scrollX;
  let top = anchorRect.bottom + window.scrollY + 8;
  if (left + 320 > window.innerWidth) left = window.innerWidth - 330;
  if (left < 10) left = 10;
  const popHeight = popover.offsetHeight;
  if (anchorRect.bottom + popHeight + 8 > window.innerHeight) {
    top = anchorRect.top + window.scrollY - popHeight - 8;
  }
  popover.style.left = left + 'px';
  popover.style.top = top + 'px';
}

// --- Data Layer: Server is source of truth, localStorage is cache ---

function loadFromCache() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      comments = JSON.parse(raw);
      comments.sort((a, b) => (a.createdAt || '').localeCompare(b.createdAt || ''));
    }
  } catch { comments = []; }
}

function saveToCache() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(comments));
}

async function fetchAllComments() {
  if (!IS_DEV) return;
  try {
    const res = await fetch('/api/comments');
    const data = await res.json();
    comments = Array.isArray(data) ? data : (data.comments || []);
    comments.sort((a, b) => (a.createdAt || '').localeCompare(b.createdAt || ''));
    saveToCache();
    applyHighlights();
    updateBadge();
    if ($panel.classList.contains('open')) renderCommentsPanel();
  } catch (e) { console.warn('fetchAllComments:', e); }
}

function updateBadge() {
  const badge = document.getElementById('commentBadge');
  if (!badge) return;
  const openCount = comments.filter(c => c.status === 'open').length;
  badge.textContent = String(openCount);
  badge.classList.toggle('zero', openCount === 0);
}

function generateId() {
  return 'c_' + Date.now() + '_' + Math.random().toString(36).slice(2, 5);
}

function showSyncStatus(ok: boolean) {
  const ind = document.getElementById('syncIndicator');
  if (!ind) return;
  ind.textContent = ok ? 'saved' : 'error';
  ind.className = 'sync-indicator ' + (ok ? 'sync-ok' : 'sync-err');
  setTimeout(() => { ind.textContent = ''; ind.className = 'sync-indicator'; }, 2000);
}

// --- SSE: Real-time updates from server ---
let _eventSource: EventSource | null = null;
let _sseReconnectTimer: ReturnType<typeof setTimeout> | null = null;

function connectSSE() {
  if (!IS_DEV || _eventSource) return;

  _eventSource = new EventSource('/api/comments/stream');

  _eventSource.addEventListener('connected', () => {
    if (_sseReconnectTimer) { clearTimeout(_sseReconnectTimer); _sseReconnectTimer = null; }
  });

  _eventSource.addEventListener('update', (e) => {
    const event = JSON.parse(e.data);
    handleServerEvent(event);
  });

  _eventSource.onerror = () => {
    _eventSource?.close();
    _eventSource = null;
    _sseReconnectTimer = setTimeout(connectSSE, 5000);
  };
}

function handleServerEvent(event: { type: string; comment?: Comment; id?: string }) {
  if (event.type === 'bulk_update') {
    fetchAllComments();
    return;
  }
  if (event.type === 'upsert' && event.comment) {
    const idx = comments.findIndex(c => c.id === event.comment!.id);
    if (idx >= 0) {
      comments[idx] = { ...comments[idx], ...event.comment };
    } else {
      comments.push(event.comment!);
    }
  } else if (event.type === 'status_change' && event.comment) {
    const idx = comments.findIndex(c => c.id === event.comment!.id);
    if (idx >= 0) comments[idx] = { ...comments[idx], ...event.comment };
  } else if (event.type === 'delete' && event.id) {
    comments = comments.filter(c => c.id !== event.id);
  } else if (event.type === 'reanchor' && event.comment) {
    const idx = comments.findIndex(c => c.id === event.comment!.id);
    if (idx >= 0) comments[idx] = { ...comments[idx], ...event.comment };
  }

  comments.sort((a, b) => (a.createdAt || '').localeCompare(b.createdAt || ''));
  saveToCache();
  applyHighlights();
  updateBadge();
  if ($panel.classList.contains('open')) renderCommentsPanel();
}

// --- Text Anchoring ---
function findClosestHeading(node: Node): { id: string; line?: number } | null {
  let el: Element | null = node.nodeType === 3 ? (node as Text).parentElement : node as Element;
  while (el && el.id !== 'main') {
    if (/^H[1-4]$/.test(el.tagName) && el.id) {
      const line = (el as HTMLElement).dataset.line ? parseInt((el as HTMLElement).dataset.line!) : undefined;
      return { id: el.id, line };
    }
    let sib = el.previousElementSibling;
    while (sib) {
      if (/^H[1-4]$/.test(sib.tagName) && sib.id) {
        const line = (sib as HTMLElement).dataset.line ? parseInt((sib as HTMLElement).dataset.line!) : undefined;
        return { id: sib.id, line };
      }
      sib = sib.previousElementSibling;
    }
    el = el.parentElement;
  }
  return null;
}

function getSourceForSection(sectionId: string): string {
  const el = document.getElementById(sectionId);
  if (!el) return 'UNKNOWN';
  const sec = el.closest('.file-section');
  return sec ? (sec as HTMLElement).dataset.source || 'UNKNOWN' : 'UNKNOWN';
}

function getParagraphIndex(node: Node, sectionId: string): number | undefined {
  const heading = document.getElementById(sectionId);
  if (!heading) return undefined;
  let blockIndex = 0;
  let sib = heading.nextElementSibling;
  while (sib) {
    const m = sib.tagName.match(/^H(\d)$/);
    if (m && parseInt(m[1]) <= parseInt(heading.tagName[1])) break;
    if (sib.contains(node) || sib === node) return blockIndex;
    blockIndex++;
    sib = sib.nextElementSibling;
  }
  return undefined;
}

function getSectionContentElements(headingEl: Element): Element[] {
  const level = parseInt(headingEl.tagName[1]);
  const elements: Element[] = [headingEl];
  let sib = headingEl.nextElementSibling;
  while (sib) {
    const m = sib.tagName.match(/^H(\d)$/);
    if (m && parseInt(m[1]) <= level) break;
    elements.push(sib);
    sib = sib.nextElementSibling;
  }
  return elements;
}

function collectTextNodes(elements: Element[]): { entries: { node: Text; start: number; end: number }[]; full: string } {
  const entries: { node: Text; start: number; end: number }[] = [];
  let pos = 0;
  for (const el of elements) {
    const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
    let node: Text | null;
    while ((node = walker.nextNode() as Text | null)) {
      const len = node.textContent!.length;
      entries.push({ node, start: pos, end: pos + len });
      pos += len;
    }
  }
  const full = entries.map(e => e.node.textContent).join('');
  return { entries, full };
}

function mapOffsetToNode(entries: { node: Text; start: number; end: number }[], offset: number) {
  for (const e of entries) {
    if (offset >= e.start && offset < e.end) {
      return { node: e.node, offset: offset - e.start };
    }
  }
  const last = entries[entries.length - 1];
  return { node: last.node, offset: last.node.textContent!.length };
}

function findTextInElements(elements: Element[], text: string, ctxBefore?: string, ctxAfter?: string) {
  const { entries, full } = collectTextNodes(elements);
  if (entries.length === 0) return null;

  let matches = findAllOccurrences(full, text);
  if (matches.length === 0) {
    const normFull = full.replace(/\s+/g, ' ');
    const normText = text.replace(/\s+/g, ' ');
    matches = findAllOccurrences(normFull, normText);
  }
  if (matches.length === 0 && text.length >= 10) {
    const best = fuzzyFind(full, text);
    if (best) matches = [best.offset];
  }
  if (matches.length === 0) return null;

  let bestIdx = matches[0];
  if (matches.length > 1 && (ctxBefore || ctxAfter)) {
    for (const idx of matches) {
      const before = full.slice(Math.max(0, idx - 20), idx);
      const after = full.slice(idx + text.length, idx + text.length + 20);
      if ((ctxBefore && before.endsWith(ctxBefore)) || (ctxAfter && after.startsWith(ctxAfter))) {
        bestIdx = idx;
        break;
      }
    }
  }

  const startMap = mapOffsetToNode(entries, bestIdx);
  const endOffset = bestIdx + text.length;
  const endMap = mapOffsetToNode(entries, endOffset - 1);

  if (startMap.node === endMap.node) {
    return { node: startMap.node, offset: startMap.offset, length: text.length, multiNode: false as const };
  } else {
    return { startNode: startMap.node, startOffset: startMap.offset, endNode: endMap.node, endOffset: endMap.offset + 1, multiNode: true as const };
  }
}

function findAllOccurrences(haystack: string, needle: string): number[] {
  const results: number[] = [];
  let idx = haystack.indexOf(needle);
  while (idx !== -1) {
    results.push(idx);
    idx = haystack.indexOf(needle, idx + 1);
  }
  return results;
}

function fuzzyFind(haystack: string, needle: string) {
  const minLen = Math.max(10, Math.floor(needle.length * 0.6));
  const lowerH = haystack.toLowerCase();
  const lowerN = needle.toLowerCase();
  let idx = lowerH.indexOf(lowerN);
  if (idx !== -1) return { offset: idx };
  for (let len = needle.length - 1; len >= minLen; len--) {
    idx = haystack.indexOf(needle.slice(0, len));
    if (idx !== -1) return { offset: idx };
  }
  for (let len = needle.length - 1; len >= minLen; len--) {
    idx = haystack.indexOf(needle.slice(needle.length - len));
    if (idx !== -1) return { offset: idx };
  }
  return null;
}

// --- CSS Custom Highlight API for all comment highlights ---
// Maps commentId → Range (for hover hit-testing and scroll-to)
const _commentRanges = new Map<string, Range>();

function applyHighlights() {
  // Clean up any legacy spans from old code
  document.querySelectorAll('.commented-text').forEach(span => {
    const parent = span.parentNode!;
    while (span.firstChild) parent.insertBefore(span.firstChild, span);
    parent.removeChild(span);
    parent.normalize();
  });
  document.querySelectorAll('.commented-block').forEach(el => el.classList.remove('commented-block'));
  document.querySelectorAll('.orphan-indicator').forEach(el => el.remove());
  _commentRanges.clear();

  // Group ranges by highlight name for CSS Custom Highlight API
  const rangesByHighlight = new Map<string, Range[]>();

  for (const c of comments) {
    if (c.status === 'dismissed') continue;

    let sectionEl: Element | null = document.getElementById(c.sectionId);
    if (!sectionEl) sectionEl = document.getElementById('main');
    if (!sectionEl) { c._orphaned = true; continue; }

    const fileSec = sectionEl.closest('.file-section');
    if (fileSec && fileSec.classList.contains('hidden')) continue;

    const contentEls = /^H[1-4]$/.test(sectionEl.tagName)
      ? getSectionContentElements(sectionEl)
      : [sectionEl];

    const highlightText = (c.status === 'resolved' && c.resolvedText) ? c.resolvedText : c.selectedText;
    const ctxBefore = (c.status === 'resolved' && c.resolvedText) ? '' : c.contextBefore;
    const ctxAfter = (c.status === 'resolved' && c.resolvedText) ? '' : c.contextAfter;
    const match = findTextInElements(contentEls, highlightText, ctxBefore, ctxAfter);

    if (match) {
      c._orphaned = false;
      try {
        const range = document.createRange();
        if (!match.multiNode) {
          range.setStart(match.node, match.offset);
          range.setEnd(match.node, match.offset + (match.length || highlightText.length));
        } else {
          range.setStart(match.startNode, match.startOffset);
          range.setEnd(match.endNode, match.endOffset);
        }

        _commentRanges.set(c.id, range);

        const cat = c.status === 'resolved' ? 'resolved' : (c.category || 'note');
        const key = `cat-${cat}`;
        if (!rangesByHighlight.has(key)) rangesByHighlight.set(key, []);
        rangesByHighlight.get(key)!.push(range);
      } catch (e) {
        if (IS_DEV) console.warn('highlight range error for', c.id, e);
        c._orphaned = true;
      }
      continue;
    }

    // Fallback: paragraph-index anchoring (uses CSS class, not spans)
    if (c.paragraphIndex != null && /^H[1-4]$/.test(sectionEl.tagName)) {
      const heading = sectionEl;
      const level = parseInt(heading.tagName[1]);
      let blockIndex = 0;
      let sib = heading.nextElementSibling;
      while (sib) {
        const m = sib.tagName.match(/^H(\d)$/);
        if (m && parseInt(m[1]) <= level) break;
        if (blockIndex === c.paragraphIndex) {
          sib.classList.add('commented-block');
          (sib as HTMLElement).dataset.commentId = c.id;
          c._orphaned = false;
          break;
        }
        blockIndex++;
        sib = sib.nextElementSibling;
      }
      if (!c._orphaned) continue;
    }

    c._orphaned = true;
  }

  // Register all highlights with the CSS Custom Highlight API
  if (CSS.highlights) {
    // Clear old comment highlights (preserve pending-selection)
    for (const key of CSS.highlights.keys()) {
      if (key.startsWith('cat-')) CSS.highlights.delete(key);
    }
    CSS.highlights.delete('comment-hover');

    for (const [key, ranges] of rangesByHighlight) {
      CSS.highlights.set(key, new Highlight(...ranges));
    }
  }

  // Orphan indicators
  for (const c of comments) {
    if (!c._orphaned || c.status === 'dismissed') continue;
    const heading = document.getElementById(c.sectionId);
    if (!heading || heading.querySelector('.orphan-indicator')) continue;
    const dot = document.createElement('span');
    dot.className = 'orphan-indicator';
    dot.dataset.commentId = c.id;
    dot.title = 'Orphaned comment: text was edited';
    const dotInner = document.createElement('span');
    dotInner.className = 'orphan-dot';
    dot.appendChild(dotInner);
    dot.addEventListener('click', (e) => {
      e.stopPropagation();
      $panel.classList.add('open');
      renderCommentsPanel();
      scrollToComment(c.id);
    });
    heading.appendChild(dot);
  }
}

function findSourceLine(node: Node): number | undefined {
  let el: Element | null = node.nodeType === 3 ? (node as Text).parentElement : node as Element;
  while (el && el.id !== 'main') {
    const line = (el as HTMLElement).dataset.line;
    if (line) return parseInt(line);
    el = el.parentElement;
  }
  return undefined;
}

// --- Diff display ---
function renderDiff(diffText: string): string {
  const lines = diffText.split('\n');
  const parts: string[] = [];
  for (const line of lines) {
    if (line.startsWith('+') && !line.startsWith('+++')) {
      const span = document.createElement('span');
      span.className = 'diff-add';
      span.textContent = line;
      parts.push(span.outerHTML + '\n');
    } else if (line.startsWith('-') && !line.startsWith('---')) {
      const span = document.createElement('span');
      span.className = 'diff-del';
      span.textContent = line;
      parts.push(span.outerHTML + '\n');
    } else {
      parts.push(escHtml(line) + '\n');
    }
  }
  return parts.join('');
}

// --- Selection & Creation ---
const mainEl = document.getElementById('main');
if (mainEl) {
  mainEl.addEventListener('mouseup', (e) => {
    setTimeout(() => handleSelection(e), 10);
  });
}

function getBlockAncestor(node: Node): Element {
  let el = node.nodeType === 3 ? (node as Text).parentElement! : node as Element;
  const inlineEls = new Set(['SPAN','STRONG','EM','B','I','CODE','A','MARK','SUB','SUP','SMALL','DEL','INS']);
  while (el.parentElement && inlineEls.has(el.tagName)) el = el.parentElement;
  return el;
}

function handleSelection(_e: Event) {
  const sel = window.getSelection();

  if (!sel || sel.isCollapsed || sel.toString().trim().length < 3) {
    $floatBtn.style.display = 'none';
    pendingSelection = null;
    if (CSS.highlights) CSS.highlights.delete('pending-selection');
    return;
  }

  const anchor = sel.anchorNode;
  if (anchor) {
    const el = anchor.nodeType === 3 ? (anchor as Text).parentElement : anchor as Element;
    if (el?.closest('input, textarea, .comment-popover, .comments-panel')) return;
  }

  const text = sel.toString().trim();
  const range = sel.getRangeAt(0).cloneRange();
  // Save rect eagerly: once focus moves or selection clears, getBoundingClientRect returns zeros
  const rect = range.getBoundingClientRect();

  // Use block-ancestor approach for context around the start of selection
  const startBlockEl = getBlockAncestor(range.startContainer);
  const { entries: startEntries, full: startFull } = collectTextNodes([startBlockEl]);

  let selStart = 0;
  for (const entry of startEntries) {
    if (entry.node === range.startContainer) {
      selStart = entry.start + range.startOffset;
      break;
    }
    if (range.startContainer.contains(entry.node)) {
      selStart = entry.start;
      break;
    }
  }
  const ctxBefore = startFull.slice(Math.max(0, selStart - 30), selStart);

  // For ctxAfter, use the block ancestor of the END of selection (handles cross-block)
  const endBlockEl = getBlockAncestor(range.endContainer);
  let ctxAfter = '';
  if (endBlockEl === startBlockEl) {
    ctxAfter = startFull.slice(selStart + text.length, selStart + text.length + 30);
  } else {
    const { entries: endEntries, full: endFull } = collectTextNodes([endBlockEl]);
    let selEnd = 0;
    for (const entry of endEntries) {
      if (entry.node === range.endContainer) {
        selEnd = entry.start + range.endOffset;
        break;
      }
      if (range.endContainer.contains(entry.node)) {
        selEnd = entry.start;
        break;
      }
    }
    ctxAfter = endFull.slice(selEnd, selEnd + 30);
  }

  const heading = findClosestHeading(range.startContainer);
  const sectionId = heading?.id || 'unknown';
  const headingLine = heading?.line;
  const sourceFile = getSourceForSection(sectionId);
  const paragraphIndex = getParagraphIndex(range.startContainer, sectionId);
  const sourceLine = findSourceLine(range.startContainer);

  pendingSelection = { text, contextBefore: ctxBefore, contextAfter: ctxAfter, sectionId, sourceFile, headingLine, sourceLine, paragraphIndex, range, rect };

  // Register CSS Custom Highlight so the selection stays visible when popover takes focus
  if (CSS.highlights) {
    CSS.highlights.set('pending-selection', new Highlight(range));
  }

  $floatBtn.style.display = 'block';
  $floatBtn.style.left = (rect.left + window.scrollX + rect.width / 2 - 40) + 'px';
  $floatBtn.style.top = (rect.bottom + window.scrollY + 4) + 'px';
}

$floatBtn.addEventListener('click', showCreatePopover);

let _selectedCategory: CommentCategory = 'note';

function showCreatePopover() {
  if (!pendingSelection) return;
  $floatBtn.style.display = 'none';
  _selectedCategory = 'note';

  const preview = pendingSelection.text.length > 100
    ? pendingSelection.text.slice(0, 97) + '...'
    : pendingSelection.text;

  const selectedDiv = document.createElement('div');
  selectedDiv.className = 'popover-selected';
  selectedDiv.textContent = `"${preview}"`;

  // Category selector
  const catRow = document.createElement('div');
  catRow.className = 'popover-categories';
  for (const cat of CATEGORIES) {
    const btn = document.createElement('button');
    btn.className = 'popover-cat-btn' + (cat.key === 'note' ? ' active' : '');
    btn.dataset.cat = cat.key;
    btn.textContent = cat.label;
    btn.addEventListener('click', () => {
      catRow.querySelectorAll('.popover-cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      _selectedCategory = cat.key;
      textarea.placeholder = cat.placeholder;
    });
    catRow.appendChild(btn);
  }

  const textarea = document.createElement('textarea');
  textarea.id = 'commentInput';
  textarea.placeholder = 'Your comment...';

  const actionsDiv = document.createElement('div');
  actionsDiv.className = 'popover-actions';

  const cancelBtn = document.createElement('button');
  cancelBtn.textContent = 'Cancel';
  cancelBtn.addEventListener('click', closePopover);

  const saveBtn = document.createElement('button');
  saveBtn.className = 'primary';
  saveBtn.textContent = 'Save';
  saveBtn.addEventListener('click', saveNewComment);

  actionsDiv.appendChild(cancelBtn);
  actionsDiv.appendChild(saveBtn);

  $popover.textContent = '';
  $popover.appendChild(selectedDiv);
  $popover.appendChild(catRow);
  $popover.appendChild(textarea);
  $popover.appendChild(actionsDiv);

  // Use eagerly-saved rect (range rect becomes zero after focus/selection change)
  positionPopover($popover, pendingSelection.rect);

  setTimeout(() => textarea.focus(), 50);
}

async function saveNewComment() {
  if (!pendingSelection) return;
  const input = document.getElementById('commentInput') as HTMLTextAreaElement;
  const text = input?.value.trim();
  if (!text) return;

  const sf = pendingSelection.sourceFile;
  const slugToDir: Record<string, string> = {
    '': 'rules',
    'campaigns': 'campaigns',
    'research': 'research',
    'dm-screen': 'dm-screen',
  };
  const slug = window.location.pathname.replace(/.*\/after-the-boom\/?/, '').replace(/\/?(index\.html)?$/, '');
  const pathPrefix = slugToDir[slug] ?? 'rules';
  const c: Comment = {
    id: generateId(),
    selectedText: pendingSelection.text,
    contextBefore: pendingSelection.contextBefore,
    contextAfter: pendingSelection.contextAfter,
    comment: text,
    category: _selectedCategory,
    sectionId: pendingSelection.sectionId,
    sourceFile: sf,
    filePath: sf && sf !== 'UNKNOWN' ? `${pathPrefix}/${sf.toLowerCase().replace(/_/g, '-')}.md` : undefined,
    nearestHeadingLine: pendingSelection.headingLine,
    sourceLine: pendingSelection.sourceLine,
    paragraphIndex: pendingSelection.paragraphIndex,
    status: 'open',
    resolution: null,
    createdAt: new Date().toISOString(),
    resolvedAt: null
  };

  comments.push(c);
  saveToCache();
  updateBadge();

  if (IS_DEV) {
    try {
      const res = await fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(c)
      });
      showSyncStatus(res.ok);
    } catch { showSyncStatus(false); }
  }

  // Flash "Saved" feedback
  $popover.textContent = '';
  const msg = document.createElement('div');
  msg.style.cssText = 'text-align:center;padding:8px;color:var(--accent);font-weight:600;';
  msg.textContent = 'Saved';
  $popover.appendChild(msg);
  setTimeout(() => {
    closePopover();
    window.getSelection()?.removeAllRanges();
    if (CSS.highlights) CSS.highlights.delete('pending-selection');
    applyHighlights();
    renderCommentsPanel();
  }, 300);
}

// --- Hover/Click on highlighted comments (range-based hit-testing) ---
let _hoverTimeout: ReturnType<typeof setTimeout> | null = null;
let _hoveredCommentId: string | null = null;

function findCommentAtPoint(x: number, y: number): string | null {
  const caretRange = document.caretRangeFromPoint(x, y);
  if (!caretRange) return null;
  for (const [commentId, range] of _commentRanges) {
    try {
      if (range.compareBoundaryPoints(Range.START_TO_START, caretRange) <= 0 &&
          range.compareBoundaryPoints(Range.END_TO_END, caretRange) >= 0) {
        return commentId;
      }
    } catch { /* ranges in different trees, skip */ }
  }
  return null;
}

let _lastHoverCheck = 0;
if (mainEl) {
  mainEl.addEventListener('mousemove', (e: MouseEvent) => {
    // Throttle to ~50ms
    const now = Date.now();
    if (now - _lastHoverCheck < 50) return;
    _lastHoverCheck = now;

    // Don't interfere when popover is showing a create form
    if (pendingSelection && $popover.style.display === 'block') return;

    const commentId = findCommentAtPoint(e.clientX, e.clientY);

    if (commentId === _hoveredCommentId) return;

    if (_hoverTimeout) clearTimeout(_hoverTimeout);

    if (!commentId) {
      // Left highlighted area
      _hoveredCommentId = null;
      if (CSS.highlights) CSS.highlights.delete('comment-hover');
      _hoverTimeout = setTimeout(() => {
        if (!$popover.matches(':hover')) closePopover();
      }, 400);
      return;
    }

    // Entered a new comment area
    _hoveredCommentId = commentId;
    const c = comments.find(x => x.id === commentId);
    if (!c) return;

    // Show hover highlight
    const hoverRange = _commentRanges.get(commentId);
    if (hoverRange && CSS.highlights) {
      CSS.highlights.set('comment-hover', new Highlight(hoverRange));
    }

    _hoverTimeout = setTimeout(() => {
      showViewPopover(c, _commentRanges.get(commentId)!);
    }, 200);
  });

  mainEl.addEventListener('mouseleave', () => {
    _hoveredCommentId = null;
    if (CSS.highlights) CSS.highlights.delete('comment-hover');
    if (_hoverTimeout) clearTimeout(_hoverTimeout);
    _hoverTimeout = setTimeout(() => {
      if (!$popover.matches(':hover')) closePopover();
    }, 400);
  });

  mainEl.addEventListener('click', (e) => {
    const commentId = findCommentAtPoint(e.clientX, e.clientY);
    if (commentId) {
      $panel.classList.add('open');
      renderCommentsPanel();
      return;
    }
    // Fallback: paragraph-level block highlights
    const block = (e.target as Element).closest('.commented-block');
    if (block) {
      $panel.classList.add('open');
      renderCommentsPanel();
    }
  });
}

$popover.addEventListener('mouseenter', () => { if (_hoverTimeout) clearTimeout(_hoverTimeout); });
$popover.addEventListener('mouseleave', () => {
  _hoveredCommentId = null;
  if (CSS.highlights) CSS.highlights.delete('comment-hover');
  _hoverTimeout = setTimeout(closePopover, 400);
});

function showViewPopover(c: Comment, rangeOrEl: Range | HTMLElement) {
  const rect = rangeOrEl.getBoundingClientRect();

  // Build popover with DOM methods for safety
  $popover.textContent = '';

  const selectedDiv = document.createElement('div');
  selectedDiv.className = 'popover-selected';
  selectedDiv.textContent = `"${c.selectedText.slice(0, 60)}"`;
  $popover.appendChild(selectedDiv);

  const commentDiv = document.createElement('div');
  commentDiv.style.cssText = 'margin:6px 0;font-size:12px;';
  commentDiv.textContent = c.comment;
  $popover.appendChild(commentDiv);

  if (c.resolution) {
    const resDiv = document.createElement('div');
    resDiv.className = 'resolution-note';
    const strong = document.createElement('strong');
    strong.textContent = 'Resolution: ';
    resDiv.appendChild(strong);
    resDiv.appendChild(document.createTextNode(c.resolution));
    $popover.appendChild(resDiv);
  }

  if (c._diffText) {
    const diffDiv = document.createElement('div');
    diffDiv.className = 'diff-display';
    // renderDiff uses escHtml and createElement for safe output
    diffDiv.innerHTML = renderDiff(c._diffText);
    $popover.appendChild(diffDiv);
  }

  const metaDiv = document.createElement('div');
  metaDiv.className = 'comment-meta';
  const catLabel = c.category ? c.category : 'note';
  metaDiv.textContent = `${catLabel} \u00b7 ${c.status} \u00b7 ${new Date(c.createdAt).toLocaleDateString()}`;
  $popover.appendChild(metaDiv);

  const actionsDiv = document.createElement('div');
  actionsDiv.className = 'popover-actions';

  if (c.status === 'open') {
    const delBtn = document.createElement('button');
    delBtn.textContent = 'Delete';
    delBtn.addEventListener('click', () => deleteComment(c.id));
    actionsDiv.appendChild(delBtn);
  } else if (c.status === 'resolved') {
    const reopenBtn = document.createElement('button');
    reopenBtn.textContent = 'Reopen';
    reopenBtn.addEventListener('click', () => reopenComment(c.id));
    actionsDiv.appendChild(reopenBtn);

    const dismissBtn = document.createElement('button');
    dismissBtn.className = 'primary';
    dismissBtn.textContent = 'Dismiss';
    dismissBtn.addEventListener('click', () => dismissComment(c.id));
    actionsDiv.appendChild(dismissBtn);
  }

  $popover.appendChild(actionsDiv);
  positionPopover($popover, rect);
}

async function deleteComment(id: string) {
  comments = comments.filter(x => x.id !== id);
  saveToCache();
  updateBadge();
  closePopover();
  applyHighlights();
  renderCommentsPanel();

  if (IS_DEV) {
    try { await fetch(`/api/comments/${encodeURIComponent(id)}`, { method: 'DELETE' }); }
    catch (e) { console.warn('deleteComment:', e); }
  }
}

async function reopenComment(id: string) {
  const c = comments.find(x => x.id === id);
  if (!c) return;
  c.status = 'open';
  c.resolution = null;
  c.resolvedAt = null;
  saveToCache();
  updateBadge();
  closePopover();
  applyHighlights();
  renderCommentsPanel();

  if (IS_DEV) {
    try {
      await fetch(`/api/comments/${encodeURIComponent(id)}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'open' })
      });
    } catch (e) { console.warn('reopenComment:', e); }
  }
}

async function dismissComment(id: string) {
  const c = comments.find(x => x.id === id);
  if (!c) return;
  c.status = 'dismissed';
  saveToCache();
  updateBadge();
  closePopover();
  applyHighlights();
  renderCommentsPanel();

  if (IS_DEV) {
    try {
      await fetch(`/api/comments/${encodeURIComponent(id)}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'dismissed' })
      });
    } catch (e) { console.warn('dismissComment:', e); }
  }
}

function closePopover() {
  $popover.style.display = 'none';
  $popover.textContent = '';
  $floatBtn.style.display = 'none';
  pendingSelection = null;
  // Clear the custom selection highlight
  if (CSS.highlights) {
    CSS.highlights.delete('pending-selection');
  }
}

// --- Comments Panel ---
let _panelCategoryFilter: CommentCategory | 'all' = 'all';

function toggleCommentsPanel() {
  $panel.classList.toggle('open');
  renderCommentsPanel();
}
document.getElementById('commentToggleBtn')?.addEventListener('click', toggleCommentsPanel);

function renderCommentsPanel() {
  const active = comments.filter(c => c.status !== 'dismissed');
  const openCount = active.filter(c => c.status === 'open').length;
  const countLabel = active.length > 0 ? ` (${openCount} open / ${active.length} total)` : '';

  // Build header with DOM
  $panel.textContent = '';
  const header = document.createElement('div');
  header.className = 'comments-panel-header';

  const h3 = document.createElement('h3');
  h3.textContent = `Comments${countLabel}`;
  header.appendChild(h3);

  const headerRight = document.createElement('div');
  headerRight.className = 'comments-panel-header-right';
  const syncInd = document.createElement('span');
  syncInd.id = 'syncIndicator';
  syncInd.className = 'sync-indicator';
  headerRight.appendChild(syncInd);
  const closeBtn = document.createElement('button');
  closeBtn.className = 'panel-close-btn';
  closeBtn.setAttribute('aria-label', 'Close');
  closeBtn.textContent = '\u00d7';
  closeBtn.addEventListener('click', () => $panel.classList.remove('open'));
  headerRight.appendChild(closeBtn);
  header.appendChild(headerRight);
  $panel.appendChild(header);

  if (active.length === 0) {
    const p = document.createElement('p');
    p.style.cssText = 'color:var(--text-muted);font-size:12px;';
    p.textContent = 'No comments yet. Select text and press c or click "+ Comment" to add one.';
    $panel.appendChild(p);
    return;
  }

  // Category filter bar
  const filterRow = document.createElement('div');
  filterRow.className = 'panel-cat-filter';
  const allBtn = document.createElement('button');
  allBtn.className = 'panel-cat-filter-btn' + (_panelCategoryFilter === 'all' ? ' active' : '');
  allBtn.textContent = 'All';
  allBtn.addEventListener('click', () => { _panelCategoryFilter = 'all'; renderCommentsPanel(); });
  filterRow.appendChild(allBtn);
  for (const cat of CATEGORIES) {
    const btn = document.createElement('button');
    btn.className = 'panel-cat-filter-btn' + (_panelCategoryFilter === cat.key ? ' active' : '');
    btn.textContent = cat.label;
    btn.addEventListener('click', () => { _panelCategoryFilter = cat.key; renderCommentsPanel(); });
    filterRow.appendChild(btn);
  }
  $panel.appendChild(filterRow);

  // Apply category filter
  const filtered = _panelCategoryFilter === 'all'
    ? active
    : active.filter(c => (c.category || 'note') === _panelCategoryFilter);

  const orphaned = filtered.filter(c => c._orphaned);
  if (orphaned.length > 0) {
    appendGroupLabel($panel, '\u26a0 Orphaned');
    const hint = document.createElement('div');
    hint.className = 'panel-group-hint';
    hint.textContent = 'Text was changed or removed. These comments can no longer be anchored.';
    $panel.appendChild(hint);
    for (const c of orphaned) appendPanelComment($panel, c, 'orphaned');
  }

  const grouped: Record<string, Comment[]> = {};
  for (const c of filtered.filter(x => !x._orphaned)) {
    const key = c.sourceFile || 'UNKNOWN';
    if (!grouped[key]) grouped[key] = [];
    grouped[key].push(c);
  }
  for (const [src, items] of Object.entries(grouped)) {
    appendGroupLabel($panel, src);
    for (const c of items) appendPanelComment($panel, c, c.status);
  }
}

function appendGroupLabel(parent: HTMLElement, text: string) {
  const div = document.createElement('div');
  div.className = 'panel-group-label';
  div.textContent = text;
  parent.appendChild(div);
}

function appendPanelComment(parent: HTMLElement, c: Comment, statusClass: string) {
  const pill = statusClass === 'orphaned' ? 'pill-orphaned'
    : c.status === 'resolved' ? 'pill-resolved' : 'pill-open';
  const label = statusClass === 'orphaned' ? 'orphaned' : c.status;

  const div = document.createElement('div');
  div.className = `panel-comment status-${statusClass}`;
  div.dataset.commentId = c.id;
  div.addEventListener('click', () => scrollToComment(c.id));

  const selectedText = document.createElement('div');
  selectedText.className = 'panel-selected-text';
  selectedText.textContent = `"${c.selectedText.slice(0, 50)}"`;
  if (c._diffText) {
    const badge = document.createElement('span');
    badge.className = 'panel-diff-badge';
    badge.textContent = 'text changed';
    selectedText.appendChild(badge);
  }
  div.appendChild(selectedText);

  const commentText = document.createElement('div');
  commentText.className = 'panel-comment-text';
  commentText.textContent = c.comment;
  div.appendChild(commentText);

  const footer = document.createElement('div');
  footer.className = 'panel-comment-footer';

  const statusSpan = document.createElement('span');
  statusSpan.className = `panel-status ${pill}`;
  statusSpan.textContent = label;
  footer.appendChild(statusSpan);

  // Category pill
  const cat = c.category || 'note';
  const catPill = document.createElement('span');
  catPill.className = `panel-cat-pill pill-cat-${cat}`;
  catPill.textContent = cat;
  footer.appendChild(catPill);

  const actionsSpan = document.createElement('span');
  actionsSpan.className = 'panel-actions';

  if (c.status === 'open' || statusClass === 'orphaned') {
    const del = document.createElement('span');
    del.className = 'panel-action panel-action-danger';
    del.textContent = 'Delete';
    del.addEventListener('click', (e) => { e.stopPropagation(); deleteComment(c.id); });
    actionsSpan.appendChild(del);
  } else if (c.status === 'resolved') {
    const reopen = document.createElement('span');
    reopen.className = 'panel-action';
    reopen.textContent = 'Reopen';
    reopen.addEventListener('click', (e) => { e.stopPropagation(); reopenComment(c.id); });
    actionsSpan.appendChild(reopen);

    const dismiss = document.createElement('span');
    dismiss.className = 'panel-action';
    dismiss.textContent = 'Dismiss';
    dismiss.addEventListener('click', (e) => { e.stopPropagation(); dismissComment(c.id); });
    actionsSpan.appendChild(dismiss);
  }

  footer.appendChild(actionsSpan);
  div.appendChild(footer);
  parent.appendChild(div);
}

function scrollToComment(id: string) {
  // Try CSS Highlight range first
  const range = _commentRanges.get(id);
  if (range) {
    const rect = range.getBoundingClientRect();
    window.scrollTo({
      top: rect.top + window.scrollY - window.innerHeight / 2,
      behavior: 'smooth',
    });
    // Flash the hover highlight briefly
    if (CSS.highlights) {
      CSS.highlights.set('comment-hover', new Highlight(range));
      setTimeout(() => CSS.highlights.delete('comment-hover'), 2000);
    }
    return;
  }
  // Fallback: paragraph-level block highlight
  const escaped = CSS.escape(id);
  const block = document.querySelector(`.commented-block[data-comment-id="${escaped}"]`) as HTMLElement;
  if (block) {
    block.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }
  // Last resort: scroll to section heading
  const c = comments.find(x => x.id === id);
  if (c?.sectionId) {
    const heading = document.getElementById(c.sectionId);
    if (heading) heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

// --- Keyboard shortcuts ---
function isInputFocused(): boolean {
  const el = document.activeElement;
  return !!el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || (el as HTMLElement).isContentEditable);
}

document.addEventListener('keydown', (e) => {
  // Cmd/Ctrl+Enter in comment textarea: save
  if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') {
    const ta = document.activeElement;
    if (ta?.id === 'commentInput') {
      e.preventDefault();
      saveNewComment();
      return;
    }
  }

  // Tab cycles category when comment popover is open
  if (e.key === 'Tab' && $popover.style.display === 'block' && pendingSelection) {
    e.preventDefault();
    const keys = CATEGORIES.map(c => c.key);
    const curIdx = keys.indexOf(_selectedCategory);
    const nextIdx = e.shiftKey
      ? (curIdx - 1 + keys.length) % keys.length
      : (curIdx + 1) % keys.length;
    _selectedCategory = keys[nextIdx];
    // Update UI: active class on pills + textarea placeholder
    $popover.querySelectorAll('.popover-cat-btn').forEach(btn => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.cat === _selectedCategory);
    });
    const ta = $popover.querySelector('#commentInput') as HTMLTextAreaElement;
    if (ta) ta.placeholder = CATEGORIES[nextIdx].placeholder;
    return;
  }

  // 'c' for comment on selection
  if (e.key === 'c' && !e.ctrlKey && !e.metaKey && !e.altKey) {
    if (isInputFocused()) return;
    const sel = window.getSelection();
    if (sel && !sel.isCollapsed && sel.toString().trim().length >= 3) {
      e.preventDefault();
      handleSelection(e);
      if (pendingSelection) showCreatePopover();
    }
    return;
  }

  // 'p' toggles comments panel
  if (e.key === 'p' && !e.ctrlKey && !e.metaKey && !e.altKey) {
    if (isInputFocused()) return;
    e.preventDefault();
    toggleCommentsPanel();
    return;
  }

  // '/' focuses search box
  if (e.key === '/' && !e.ctrlKey && !e.metaKey && !e.altKey) {
    if (isInputFocused()) return;
    e.preventDefault();
    (document.querySelector('.search-box input') as HTMLInputElement)?.focus();
    return;
  }

  // Escape: close popover, panel, or blur search
  if (e.key === 'Escape') {
    if ($popover.style.display === 'block') {
      closePopover();
      e.stopPropagation();
      return;
    }
    const searchInput = document.querySelector('.search-box input') as HTMLInputElement;
    if (document.activeElement === searchInput) {
      searchInput.blur();
      return;
    }
    if ($panel.classList.contains('open')) {
      $panel.classList.remove('open');
    }
  }
});

// Close on outside click
document.addEventListener('mousedown', (e) => {
  const target = e.target as Element;
  if ($popover.style.display === 'block' && !$popover.contains(target) && !target.closest('.comment-float-btn')) {
    closePopover();
  }
  if ($panel.classList.contains('open') && !$panel.contains(target) && !target.closest('.comment-toggle-btn')) {
    $panel.classList.remove('open');
  }
});

// Re-apply highlights when filters change
document.addEventListener('filters-changed', () => applyHighlights());

// --- Init ---
loadFromCache();
applyHighlights();
updateBadge();
fetchAllComments();
connectSSE();
</script>
