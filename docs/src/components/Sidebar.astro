---
interface TocEntry {
  level: number;
  id: string;
  title: string;
}
interface SectionGroup {
  source: string;
  color: string;
  toc: TocEntry[];
  title: string;
  titleId: string;
}
interface Props {
  sections: SectionGroup[];
}
const { sections } = Astro.props;
---

<nav class="sidebar" id="sidebar">
  {sections.map(({ source, color, toc, title, titleId }) => (
    <div class="nav-group" data-source={source}>
      <a class="nav-source" style={`border-left:3px solid ${color}`} href={`#${titleId}`}>{title}</a>
      {toc.map(({ level, id, title }) => (
        <a
          class={`nav-link ${level === 3 ? 'nav-h3' : 'nav-h2'}`}
          href={`#${id}`}
        >{title}</a>
      ))}
    </div>
  ))}
</nav>
