<!--
  Milkdown Crepe editor: dev-only, always-on inline WYSIWYG markdown editing.
  Replaces rendered content with editable Milkdown instances on every section.
  Autosaves to disk via /api/editor/save. Astro HMR re-renders automatically.
  Includes: floating toolbar, slash menu, block handles, undo/redo (Ctrl+Z).
  Comments persist to SQLite via /api/comments.
-->

<script>
import { ensureMilkdownImports, getMk } from '../lib/editor/milkdown-imports';
import { injectToolbarExtras, TOOLBAR_ICONS } from '../lib/editor/toolbar';
import { rebuildSidebar } from '../lib/editor/sidebar';
import { contentHash } from '../lib/editor/content-hash';
import { trySave, showIndicator, checkForExternalChanges, resolveConflict, type EditorState } from '../lib/editor/autosave';
import { commentsPlugin, commentsPluginKey, setComments } from '../lib/editor/comments-plugin';
import { fetchComments, toCommentRange, formatTime, subscribeToComments, resolveComment, deleteComment } from '../lib/editor/comments-api';
import { addCommentCard, removeCommentCard } from '../lib/editor/comment-cards';

const AUTOSAVE_DELAY = 2000;

const editors = new Map<Element, EditorState>();
let Crepe: any = null;

async function initAllEditors() {
  const sections = document.querySelectorAll('.file-section[data-entry-id]');
  if (sections.length === 0) return;

  if (!Crepe) {
    const [mod] = await Promise.all([
      import('@milkdown/crepe'),
      ensureMilkdownImports(),
    ]);
    Crepe = mod.Crepe;
  }

  for (const section of sections) {
    if (editors.has(section)) continue;
    await mountEditor(section as HTMLElement);
  }

  // Load existing comments after all editors are mounted
  loadComments();

  // Subscribe to real-time comment updates
  subscribeToComments((event) => {
    if (event.type === 'bulk_update' || event.type === 'upsert') {
      loadComments(); // Reload all on any change
    }
    if (event.type === 'delete' || event.type === 'status_change') {
      loadComments();
    }
  });
}

/** Remove a single comment's highlight decoration. */
function removeHighlightById(state: EditorState, mk: any, cid: string) {
  if (!mk) return;
  try {
    state.crepe.editor.action((ctx: any) => {
      const view = ctx.get(mk.editorViewCtx);
      const current = commentsPluginKey.getState(view.state);
      setComments(view, (current?.comments || []).filter((r: any) => r.id !== cid));
    });
  } catch {}
}

/** Load comments from the API and apply highlights + cards to all editors. */
async function loadComments() {
  let apiComments;
  try {
    apiComments = await fetchComments('open');
  } catch {
    return; // API not available
  }

  const mk = getMk();
  if (!mk) return;

  for (const [section, state] of editors) {
    const sourceFile = section.getAttribute('data-source') || '';
    // Filter comments for this section's source file
    const sectionComments = apiComments.filter(c => c.source_file === sourceFile);
    const ranges = sectionComments.map(toCommentRange);

    // Update highlight decorations
    try {
      state.crepe.editor.action((ctx: any) => {
        const view = ctx.get(mk.editorViewCtx);
        setComments(view, ranges);
      });
    } catch {}

    // Update cards
    const container = state.container;
    for (const c of sectionComments) {
      addCommentCard(container, {
        id: c.id,
        selectedText: c.selected_text,
        comment: c.comment,
        author: 'Johannes',
        timestamp: formatTime(c.created_at),
      }, {
        onResolve: async (cid) => {
          removeCommentCard(container, cid);
          removeHighlightById(state, mk, cid);
          await resolveComment(cid);
        },
        onEdit: (cid) => console.log('[comment] Edit:', cid),
        onDelete: async (cid) => {
          removeCommentCard(container, cid);
          removeHighlightById(state, mk, cid);
          await deleteComment(cid);
        },
      });
    }
  }
}

async function mountEditor(section: HTMLElement) {
  const template = section.querySelector('template.raw-md') as HTMLTemplateElement;
  if (!template) return;
  const rawMd = template.content.textContent || '';

  // Hide rendered content and strip IDs to prevent getElementById collisions
  for (const child of Array.from(section.children)) {
    if (child.classList.contains('editor-container') || child.tagName === 'TEMPLATE' || child.classList.contains('save-indicator')) continue;
    (child as HTMLElement).style.display = 'none';
    child.querySelectorAll('[id]').forEach(el => el.removeAttribute('id'));
  }

  const indicator = document.createElement('span');
  indicator.className = 'save-indicator';
  section.appendChild(indicator);

  const container = document.createElement('div');
  container.className = 'editor-container';
  section.appendChild(container);

  const crepe = new Crepe({
    root: container,
    defaultValue: rawMd,
    features: {
      [Crepe.Feature.Toolbar]: true,
      [Crepe.Feature.BlockEdit]: true,
      [Crepe.Feature.LinkTooltip]: true,
      [Crepe.Feature.ListItem]: true,
      [Crepe.Feature.Table]: true,
      [Crepe.Feature.Cursor]: true,
      [Crepe.Feature.Placeholder]: true,
      [Crepe.Feature.ImageBlock]: false,
      [Crepe.Feature.CodeMirror]: false,
      [Crepe.Feature.Latex]: false,
    },
    featureConfigs: {
      [Crepe.Feature.Placeholder]: { text: 'Type "/" for commands...', mode: 'block' },
      [Crepe.Feature.Toolbar]: TOOLBAR_ICONS,
    },
  });

  crepe.editor.use(commentsPlugin);

  const state: EditorState = {
    crepe, container, indicator,
    lastSavedMarkdown: rawMd, // temporary — updated after editor init
    lastKnownHash: null,
    autosaveInterval: null,
  };
  editors.set(section, state);

  await crepe.create();

  // Sync lastSavedMarkdown with editor's normalized output.
  // Milkdown's parse→serialize round-trip normalizes whitespace/newlines,
  // so getMarkdown() !== rawMd even with no user edits. Without this sync,
  // every autosave tick thinks content changed and triggers a save storm.
  try {
    const normalized = crepe.getMarkdown();
    state.lastSavedMarkdown = normalized;
    state.lastKnownHash = contentHash(normalized);
  } catch {}

  // Section context for comment creation
  const sectionCtx = {
    sectionId: section.getAttribute('data-source') || '',
    sourceFile: section.getAttribute('data-source') || '',
  };
  await injectToolbarExtras(crepe, container, sectionCtx);

  // Autosave
  const onSaved = () => rebuildSidebar(editors);
  state.autosaveInterval = setInterval(async () => {
    const result = await trySave(section, editors, onSaved);
    if (result === 'conflict') {
      if (state.autosaveInterval) clearInterval(state.autosaveInterval);
      state.autosaveInterval = null;
      console.log(`[editor] Conflict in ${section.getAttribute('data-entry-id')} — autosave paused`);
    }
  }, AUTOSAVE_DELAY);

  // Backspace at start of heading → convert to paragraph
  container.addEventListener('keydown', (e: KeyboardEvent) => {
    const mk = getMk();
    if (e.key !== 'Backspace' || !mk) return;
    try {
      crepe.editor.action((ctx: any) => {
        const view = ctx.get(mk.editorViewCtx);
        const { $from, empty } = view.state.selection;
        if (!empty || $from.parentOffset !== 0) return;
        if ($from.parent.type.name !== 'heading') return;
        e.preventDefault();
        e.stopImmediatePropagation();
        ctx.get(mk.commandsCtx).call(mk.turnIntoTextCommand.key);
      });
    } catch {}
  }, true);

  // Cmd+S immediate save
  container.addEventListener('keydown', async (e: KeyboardEvent) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 's') {
      e.preventDefault();
      e.stopPropagation();
      await trySave(section, editors, () => rebuildSidebar(editors));
    }
  });
}

window.addEventListener('focus', () => checkForExternalChanges(editors));

initAllEditors();
</script>
