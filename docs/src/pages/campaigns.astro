---
import { getCollection, render } from 'astro:content';
import RulesLayout from '../layouts/RulesLayout.astro';

const SOURCE_ORDER = [
  'PLAYER-REFERENCE',
  'PC-SMORGASBORD',
];

const FILE_COLORS: Record<string, string> = {
  'PLAYER-REFERENCE': '#5c7a6a',
  'PC-SMORGASBORD':   '#6a5c7a',
};

const allEntries = await getCollection('campaigns');

const entries = allEntries.sort((a, b) => {
  const aName = a.id.replace(/\.md$/, '').toUpperCase();
  const bName = b.id.replace(/\.md$/, '').toUpperCase();
  const aIdx = SOURCE_ORDER.indexOf(aName);
  const bIdx = SOURCE_ORDER.indexOf(bName);
  return (aIdx === -1 ? 999 : aIdx) - (bIdx === -1 ? 999 : bIdx);
});

interface TocEntry { level: number; id: string; title: string; }
interface SectionData {
  source: string;
  color: string;
  toc: TocEntry[];
  Content: any;
  rawMd: string;
  entryId: string;
  title: string;
  titleId: string;
}

const sections: SectionData[] = [];

for (const entry of entries) {
  const source = entry.id.replace(/\.md$/, '').toUpperCase();
  const color = FILE_COLORS[source] || '#666';
  const { Content, headings } = await render(entry);

  const h1 = headings.find(h => h.depth === 1);
  const title = h1?.text || source;
  const titleId = h1?.slug || source.toLowerCase();
  const toc: TocEntry[] = headings
    .filter(h => h.depth >= 2 && h.depth <= 3)
    .map(h => ({ level: h.depth, id: h.slug, title: h.text }));

  sections.push({ source, color, toc, Content, rawMd: entry.body, entryId: entry.id, title, titleId });
}

const sidebarSections = sections.map(s => ({
  source: s.source,
  color: s.color,
  toc: s.toc,
  title: s.title,
  titleId: s.titleId,
}));
---

<RulesLayout sections={sidebarSections} currentTab="campaigns">
  {sections.map(({ source, color, Content, toc, rawMd, entryId }) => (
    <section class="file-section" data-source={source} data-collection="campaigns" data-entry-id={entryId}>
      <Content />
      {!import.meta.env.PROD && <template class="raw-md">{rawMd}</template>}
    </section>
  ))}
</RulesLayout>
