---
import { getCollection, render } from 'astro:content';
import RulesLayout from '../layouts/RulesLayout.astro';

// Same order as the Python build script
const SOURCE_ORDER = [
  'CORE',
  'DESIGN-CORE',
  'MAGIC',
  'DESIGN-MAGIC',
  'CHARACTER',
  'DESIGN-CHARACTER',
  'EDGES',
  'DESIGN-EDGES',
  'EQUIPMENT',
  'DESIGN-EQUIPMENT',
  'GAMBITS',
  'DESIGN-GAMBITS',
  'BACKGROUNDS',
  'DESIGN-BACKGROUNDS',
  'DESIGN',
];

const FILE_COLORS: Record<string, string> = {
  CORE:               '#8b7355',
  MAGIC:              '#7a5c7a',
  EDGES:              '#5c6a7a',
  EQUIPMENT:          '#7a5c5c',
  GAMBITS:            '#5c7a5c',
  CHARACTER:          '#7a7a5c',
  BACKGROUNDS:        '#5c7a7a',
  DESIGN:             '#6a5c7a',
  'DESIGN-CORE':        '#a89070',
  'DESIGN-MAGIC':       '#9a7a9a',
  'DESIGN-CHARACTER':   '#9a9a7a',
  'DESIGN-EDGES':       '#8a9baa',
  'DESIGN-EQUIPMENT':   '#aa8a7a',
  'DESIGN-GAMBITS':     '#7a9a7a',
  'DESIGN-BACKGROUNDS': '#7a9a9a',
};

// Load all rules entries
const allEntries = await getCollection('rules');

// Hide DESIGN-* files in production (GitHub Pages) — keep them in dev
const isDesign = (id: string) => id.replace(/\.md$/, '').toUpperCase().startsWith('DESIGN');
const filtered = import.meta.env.PROD
  ? allEntries.filter(e => !isDesign(e.id))
  : allEntries;

// Sort by SOURCE_ORDER, unknown files at the end
const entries = filtered.sort((a, b) => {
  const aName = a.id.replace(/\.md$/, '').toUpperCase();
  const bName = b.id.replace(/\.md$/, '').toUpperCase();
  const aIdx = SOURCE_ORDER.indexOf(aName);
  const bIdx = SOURCE_ORDER.indexOf(bName);
  return (aIdx === -1 ? 999 : aIdx) - (bIdx === -1 ? 999 : bIdx);
});

// Build section data: render each entry and use Astro's heading slugs
interface TocEntry { level: number; id: string; title: string; }
interface SectionData {
  source: string;
  color: string;
  toc: TocEntry[];
  Content: any;
}

const sections: SectionData[] = [];

for (const entry of entries) {
  const source = entry.id.replace(/\.md$/, '').toUpperCase();
  const color = FILE_COLORS[source] || '#666';
  const { Content, headings } = await render(entry);

  // Use Astro's heading slugs directly (already prefixed by remark plugin)
  // H1 titles are system-builder metadata — skip them in the sidebar
  const toc: TocEntry[] = headings
    .filter(h => h.depth >= 2 && h.depth <= 3)
    .map(h => ({ level: h.depth, id: h.slug, title: h.text }));

  sections.push({ source, color, toc, Content });
}

// Build sources for filter bar (DESIGN-* already excluded in prod via filtered)
const sources = sections.map(s => ({ name: s.source, color: s.color }));

// Build sidebar sections
const sidebarSections = sections.map(s => ({
  source: s.source,
  color: s.color,
  toc: s.toc,
}));
---

<RulesLayout sections={sidebarSections} sources={sources}>
  {sections.map(({ source, color, Content, toc }) => (
    <section class="file-section" data-source={source}>
      <Content />
    </section>
  ))}
</RulesLayout>
