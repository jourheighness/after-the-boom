{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "type": "stdio"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless"
      ],
      "type": "stdio"
    },
    "comments": {
      "command": "npx",
      "args": [
        "tsx",
        "../tools/comments-server/src/mcp-server.ts"
      ],
      "type": "stdio"
    }
  }
}
