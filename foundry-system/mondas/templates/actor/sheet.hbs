<div class="tab-content" data-tab="play" {{#unless (eq activeTab 'play')}}hidden{{/unless}}>

{{!-- Incapacitated Banner --}}
{{#if incapacitated}}
<div class="status-banner banner-critical">INCAPACITATED — cannot act</div>
{{/if}}

{{!-- Resource Strip: Drain | Guard | [spacer] | Arm | Hrt | Wnd | Crt --}}
<div class="resource-strip">
  <div class="gauge" title="Drain — spend to fuel bonus dice, thaumatech, and crits">
    <span class="gauge-label">Drain</span>
    <div class="gauge-boxes">
      {{#times drain.max}}
      <span class="gauge-box drain {{#if (lt this ../drain.value)}}filled{{/if}}" data-action="toggleDrainBox" data-index="{{this}}"></span>
      {{/times}}
    </div>
  </div>

  <div class="gauge" title="Guard — absorbs incoming damage before it reaches Harm">
    <span class="gauge-label">Guard</span>
    <div class="gauge-boxes">
      {{#times guard.max}}
      <span class="gauge-box guard {{#if (lt this ../guard.value)}}filled{{/if}}" data-action="toggleGuardBox" data-index="{{this}}"></span>
      {{/times}}
    </div>
  </div>

  <div class="harm-container">
    <div class="armor-block" title="Armor — reduces overflow damage after Guard breaks">
      <span class="gauge-label">Arm</span>
      <span class="armor-val">{{armor}}</span>
    </div>

    <div class="harm-group" title="Hurt — minor harm (1-2 overflow)">
      <span class="gauge-label">Hrt</span>
      <span class="harm-box hurt {{#if harm.hurt.slot1.filled}}filled{{/if}}" data-action="toggleHarm" data-level="hurt" data-slot="slot1"></span>
      <span class="harm-box hurt {{#if harm.hurt.slot2.filled}}filled{{/if}}" data-action="toggleHarm" data-level="hurt" data-slot="slot2"></span>
    </div>

    <div class="harm-group" title="Wound — serious harm (3-4 overflow), applies Wounded">
      <span class="gauge-label">Wnd</span>
      <span class="harm-box wound {{#if harm.wounded.slot1.filled}}filled{{/if}}" data-action="toggleHarm" data-level="wounded" data-slot="slot1"></span>
      <span class="harm-box wound {{#if harm.wounded.slot2.filled}}filled{{/if}}" data-action="toggleHarm" data-level="wounded" data-slot="slot2"></span>
    </div>

    <div class="harm-group" title="Crit — critical harm (5+ overflow), consider a Scar">
      <span class="gauge-label">Crt</span>
      <span class="harm-box crit {{#if harm.critical.slot1.filled}}filled{{/if}}" data-action="toggleHarm" data-level="critical" data-slot="slot1"></span>
      <span class="harm-box crit {{#if harm.critical.slot2.filled}}filled{{/if}}" data-action="toggleHarm" data-level="critical" data-slot="slot2"></span>
    </div>
  </div>
</div>

{{!-- Stats --}}
<div class="stats-row">
  {{#each stats}}
  <div class="stat-block">
    <div class="stat-top">
      <div class="stat-icon-col">
        <span class="stat-icon stat-icon-{{key}}"></span>
        <span class="stat-label">{{label}}</span>
      </div>
      <input type="number" class="stat-value" name="system.stats.{{key}}" value="{{value}}" min="1" max="4">
    </div>
    <div class="stat-roll-buttons">
      <button type="button" data-action="rollStat" data-stat="{{key}}" data-roll-type="defense" title="Defense"><i class="fa-solid fa-shield-halved"></i></button>
      <button type="button" data-action="rollStat" data-stat="{{key}}" data-roll-type="stakes" title="Stakes"><i class="fa-solid fa-scale-balanced stakes-icon"></i></button>
    </div>
  </div>
  {{/each}}
</div>

{{!-- Combat Strip: all usable items in one flex-wrap container --}}
<div class="combat-strip">
  {{#each weapons}}
  <div class="combat-chip {{#if (eq quantity 0)}}chip-spent{{/if}}" data-action="attackWeapon" data-index="{{@index}}" {{#if tip}}data-tip="{{tip}}"{{/if}}>
    <span class="chip-cell">{{#if isThrown}}<i class="fa-solid fa-bomb"></i>{{else}}<i class="fa-solid fa-gun"></i>{{/if}}{{#if name}}{{name}}{{else}}(unnamed){{/if}}</span>
    <span class="chip-cell cell-die">{{dieBadge}}</span>
    {{#if isThrown}}<span class="chip-cell cell-qty">×{{quantity}}</span>{{/if}}
    {{#if gambitName}}<span class="chip-cell cell-gambit"><i class="fa-solid fa-dice-four"></i>{{gambitName}}</span>{{/if}}
  </div>
  {{/each}}
  {{#each edges}}
  <div class="combat-chip" data-action="showEdge" data-index="{{@index}}" {{#if tip}}data-tip="{{tip}}"{{/if}}>
    <span class="chip-cell"><i class="fa-solid fa-fingerprint"></i>{{#if name}}{{name}}{{else}}(unnamed){{/if}}</span>
    {{#if gambitName}}<span class="chip-cell cell-gambit"><i class="fa-solid fa-dice-four"></i>{{gambitName}}</span>{{/if}}
  </div>
  {{/each}}
  {{#each equipment}}
  <div class="combat-chip" data-action="showEquipment" data-index="{{@index}}" {{#if tip}}data-tip="{{tip}}"{{/if}}>
    <span class="chip-cell"><i class="fa-solid fa-toolbox"></i>{{#if name}}{{name}}{{else}}(unnamed){{/if}}</span>
    <span class="chip-cell cell-qty">×{{quantity}}</span>
  </div>
  {{/each}}
</div>

{{!-- Bottom Panels --}}
<div class="bottom-panels">
  {{!-- Left: Dice Tracking --}}
  <div class="panel">
    <span class="panel-label">Dice Tracking</span>
    <div class="panel-content">
      {{#if setupDie.active}}
      <div class="die-item">
        <div class="die-box die-setup-tracked" title="Setup die — automatically added to next roll">
          {{setupDie.value}}
          <span class="die-close" data-action="clearSetupDie">×</span>
        </div>
        <div class="die-item-label">{{#if setupDie.source}}{{setupDie.source}}{{else}}SETUP{{/if}}</div>
      </div>
      {{/if}}
      {{#each trackedOut}}
      <div class="die-item">
        <div class="die-box die-tracked" data-action="rollTrackedDie" data-index="{{realIndex}}" title="Click to roll — sustained die on target">
          {{die}}
          <span class="die-close" data-action="removeTrackedDie" data-index="{{realIndex}}">×</span>
        </div>
        <div class="die-item-label">{{label}}</div>
      </div>
      {{/each}}
      <div class="die-item">
        <div class="die-box die-add" data-action="addTrackedDie" data-dtype="sustained-enemy" title="Add a tracked die">+</div>
      </div>
    </div>
  </div>

  {{!-- Right: Conditions (hidden when nothing active) --}}
  {{#if hasConditions}}
  <div class="panel">
    <span class="panel-label">Conditions</span>
    <div class="panel-content">
      {{#if conditions.stunned}}<span class="condition-pill condition active" data-action="toggleCondition" data-condition="stunned" title="Stunned — lose your next action"><i class="fa-solid fa-bolt"></i> Stunned</span>{{/if}}
      {{#if conditions.shaken}}<span class="condition-pill condition active" data-action="toggleCondition" data-condition="shaken" title="Shaken — Snag on all rolls until recovered"><i class="fa-solid fa-hand"></i> Shaken</span>{{/if}}
      {{#if conditions.prone}}<span class="condition-pill condition active" data-action="toggleCondition" data-condition="prone" title="Prone — Snag on attacks, opponents get Boon against you"><i class="fa-solid fa-person-falling"></i> Prone</span>{{/if}}
      {{#if cracked}}<span class="condition-pill cracked" title="Cracked — all Drain spent"><i class="fa-solid fa-heart-crack"></i> Cracked</span>{{/if}}
      {{#if wounded}}<span class="condition-pill wounded" title="Wounded — Wound slot filled"><i class="fa-solid fa-droplet"></i> Wounded</span>{{/if}}
      {{#if critical}}<span class="condition-pill critical" title="Critical — Crit slot filled, must spend Drain to act"><i class="fa-solid fa-skull"></i> Critical</span>{{/if}}
      {{#each trackedSelf}}
      <div class="combat-chip sustained-self-chip" data-action="rollTrackedDie" data-index="{{realIndex}}" title="Sustained damage on you — click to roll">
        <span class="chip-cell"><i class="fa-solid fa-arrows-spin"></i> Sust</span>
        <span class="chip-cell cell-die">{{die}}</span>
        <span class="die-close" data-action="removeTrackedDie" data-index="{{realIndex}}">×</span>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}
</div>

{{!-- Footer: Damage button --}}
<div class="footer-bar">
  <button type="button" class="take-dmg-btn" data-action="openDamageDialog" title="Open damage dialog — apply damage, conditions, or sustained dice"><i class="fa-solid fa-burst"></i> Damage</button>
</div>

</div>
