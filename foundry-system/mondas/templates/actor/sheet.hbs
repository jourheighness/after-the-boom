<div class="tab-content" data-tab="play" {{#unless (eq activeTab 'play')}}hidden{{/unless}}>

{{!-- Status Strip — pills left, dmg + condition controls right --}}
{{#if incapacitated}}
<div class="status-banner banner-critical">INCAPACITATED — cannot act</div>
{{else}}
<div class="status-strip">
  <div class="status-pills">
    {{#if critical}}<span class="status-pill pill-critical">CRITICAL</span>{{/if}}
    {{#if wounded}}<span class="status-pill pill-wounded">WOUNDED</span>{{/if}}
    {{#if cracked}}<span class="status-pill pill-cracked">CRACKED</span>{{/if}}
    {{#if conditions.stunned}}<span class="status-pill pill-condition">STUNNED</span>{{/if}}
    {{#if conditions.shaken}}<span class="status-pill pill-condition">SHAKEN</span>{{/if}}
    {{#if conditions.prone}}<span class="status-pill pill-condition">PRONE</span>{{/if}}
  </div>
  <div class="strip-controls">
    <div class="strip-input-group">
      <span class="strip-label">Dmg</span>
      <input type="number" class="strip-input" value="" min="0" placeholder="—">
    </div>
    <button type="button" class="strip-btn" data-action="takeDamage">Apply</button>
    <button type="button" class="condition-btn {{#if hasActiveCondition}}has-active{{/if}}" data-action="toggleConditionPopover" title="Toggle Conditions"><i class="fa-solid fa-person-falling-burst"></i></button>
    {{#if conditionPopoverOpen}}
    <div class="condition-popover">
      <div class="pop-item {{#if conditions.stunned}}active{{/if}}" data-action="toggleCondition" data-condition="stunned"><span class="pop-check">{{#if conditions.stunned}}✓{{/if}}</span> Stunned</div>
      <div class="pop-item {{#if conditions.shaken}}active{{/if}}" data-action="toggleCondition" data-condition="shaken"><span class="pop-check">{{#if conditions.shaken}}✓{{/if}}</span> Shaken</div>
      <div class="pop-item {{#if conditions.prone}}active{{/if}}" data-action="toggleCondition" data-condition="prone"><span class="pop-check">{{#if conditions.prone}}✓{{/if}}</span> Prone</div>
    </div>
    {{/if}}
  </div>
</div>
{{/if}}

{{!-- Stats --}}
<div class="stats-row">
  {{#each stats}}
  <div class="stat-block">
    <div class="stat-top">
      <div class="stat-icon-col">
        <span class="stat-icon stat-icon-{{key}}"></span>
        <span class="stat-label">{{label}}</span>
      </div>
      <input type="number" class="stat-value" name="system.stats.{{key}}" value="{{value}}" min="1" max="4">
    </div>
    <div class="stat-roll-buttons">
      <button type="button" data-action="rollStat" data-stat="{{key}}" data-roll-type="defense" title="Defense"><i class="fa-solid fa-shield-halved"></i></button>
      <button type="button" data-action="rollStat" data-stat="{{key}}" data-roll-type="stakes" title="Stakes"><i class="fa-solid fa-scale-balanced stakes-icon"></i></button>
    </div>
  </div>
  {{/each}}
</div>

{{!-- Weapon Minicards --}}
{{#if weapons.length}}
<div class="combat-strip">
  {{#each weapons}}
  <div class="combat-weapon {{#if (eq quantity 0)}}weapon-spent{{/if}}" data-action="attackWeapon" data-index="{{@index}}">
    <span class="combat-weapon-name">{{#if name}}{{name}}{{else}}(unnamed){{/if}}</span>
    <span class="combat-weapon-die">{{dieBadge}}</span>
    {{#if gambitName}}<span class="combat-weapon-gambit">{{gambitName}}</span>{{/if}}
    {{#if isThrown}}<span class="combat-weapon-qty">×{{quantity}}</span>{{/if}}
  </div>
  {{/each}}
</div>
{{/if}}

{{!-- Edge Minicards --}}
{{#if edges.length}}
<div class="combat-strip">
  {{#each edges}}
  <div class="combat-weapon" data-action="showEdge" data-index="{{@index}}">
    <span class="combat-weapon-name">{{#if name}}{{name}}{{else}}(unnamed){{/if}}</span>
    {{#if gambitName}}<span class="combat-weapon-gambit">{{gambitName}}</span>{{/if}}
  </div>
  {{/each}}
</div>
{{/if}}

{{!-- Equipment Minicards --}}
{{#if equipment.length}}
<div class="combat-strip">
  {{#each equipment}}
  <div class="combat-weapon" data-action="showEquipment" data-index="{{@index}}">
    <span class="combat-weapon-name">{{#if name}}{{name}}{{else}}(unnamed){{/if}}</span>
    <span class="combat-weapon-qty">×{{quantity}}</span>
  </div>
  {{/each}}
</div>
{{/if}}

{{!-- Defense Track: Guard → Armor → [Hurt | Wound | Crit] --}}
<div class="defense-track">
  <div class="track">
    <span class="track-label">Guard</span>
    <div class="track-boxes">
      {{#times guard.max}}
      <span class="track-box guard {{#if (lt this ../guard.value)}}filled{{/if}}" data-action="toggleGuardBox" data-index="{{this}}"></span>
      {{/times}}
    </div>
    <span class="track-counter">{{guardRemaining}}/{{guard.max}}</span>
  </div>

  <div class="armor-block">
    <span class="armor-label">Armor</span>
    <span class="armor-value">{{armor}}</span>
  </div>

  <div class="harm-container">
    <div class="harm-group">
      <span class="harm-level">Hurt</span>
      <span class="harm-box {{#if harm.hurt.slot1.filled}}filled{{/if}}" data-action="toggleHarm" data-level="hurt" data-slot="slot1"></span>
      <span class="harm-box {{#if harm.hurt.slot2.filled}}filled{{/if}}" data-action="toggleHarm" data-level="hurt" data-slot="slot2"></span>
    </div>
    <div class="harm-group">
      <span class="harm-level">Wound</span>
      <span class="harm-box wounded {{#if harm.wounded.slot1.filled}}filled{{/if}}" data-action="toggleHarm" data-level="wounded" data-slot="slot1"></span>
      <span class="harm-box wounded {{#if harm.wounded.slot2.filled}}filled{{/if}}" data-action="toggleHarm" data-level="wounded" data-slot="slot2"></span>
    </div>
    <div class="harm-group">
      <span class="harm-level">Crit</span>
      <span class="harm-box critical {{#if harm.critical.slot1.filled}}filled{{/if}}" data-action="toggleHarm" data-level="critical" data-slot="slot1"></span>
      <span class="harm-box critical {{#if harm.critical.slot2.filled}}filled{{/if}}" data-action="toggleHarm" data-level="critical" data-slot="slot2"></span>
    </div>
  </div>
</div>

{{!-- Drain --}}
<div class="drain-row">
  <span class="track-label">Drain</span>
  <div class="track-boxes">
    {{#times drain.max}}
    <span class="track-box drain {{#if (lt this ../drain.value)}}filled{{/if}}" data-action="toggleDrainBox" data-index="{{this}}"></span>
    {{/times}}
  </div>
  <span class="track-counter">{{drainRemaining}}/{{drain.max}}</span>
</div>

{{!-- Die Tracking --}}
<div class="die-track">
  <div class="die-panel">
    <div class="die-panel-label">Tracking</div>
    <div class="dice-row">
      {{#if setupDie.active}}
      <div class="die-item">
        <div class="die-box die-setup-tracked" title="Setup die — used in roll dialog">
          {{setupDie.value}}
          <span class="die-close" data-action="clearSetupDie">×</span>
        </div>
        <div class="die-item-label">{{#if setupDie.source}}{{setupDie.source}}{{else}}SETUP{{/if}}</div>
      </div>
      {{/if}}
      {{#each trackedOut}}
      <div class="die-item">
        <div class="die-box die-tracked" data-action="rollTrackedDie" data-index="{{realIndex}}" title="Click to roll">
          {{die}}
          <span class="die-close" data-action="removeTrackedDie" data-index="{{realIndex}}">×</span>
        </div>
        <div class="die-item-label">{{label}}</div>
      </div>
      {{/each}}
      <div class="die-item">
        <div class="die-box die-add" data-action="addTrackedDie" data-dtype="sustained-enemy">+</div>
      </div>
    </div>
  </div>
  <div class="die-panel">
    <div class="die-panel-label">On You</div>
    <div class="dice-row">
      {{#each trackedSelf}}
      <div class="die-item">
        <div class="die-box die-tracked" data-action="rollTrackedDie" data-index="{{realIndex}}" title="Click to roll">
          {{die}}
          <span class="die-close" data-action="removeTrackedDie" data-index="{{realIndex}}">×</span>
        </div>
        <div class="die-item-label">{{label}}</div>
      </div>
      {{/each}}
      <div class="die-item">
        <div class="die-box die-add" data-action="addTrackedDie" data-dtype="sustained-self">+</div>
      </div>
    </div>
  </div>
</div>

</div>
