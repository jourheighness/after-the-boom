{{!-- MONDAS Roll — Chat Card (pending / resolved) --}}
<div class="mondas-roll-chat" data-phase="{{phase}}">
  <div class="roll-header">
    <strong>{{statLabel}}</strong> &mdash; {{rollTypeLabel}}
  </div>

  <div class="pool-desc">{{poolDesc}} = {{poolLabel}}</div>

  <div class="dice-grid">
    {{#each dice}}
    {{#if isWeapon}}
    <span class="die-weapon-wrap">
      <span
        class="die-result die-weapon {{colorClass}} {{#if isGambitEligible}}gambit-eligible{{/if}} {{#if sacrificed}}sacrificed{{/if}}"
        data-index="{{index}}"
      ><span class="die-weapon-inner">{{value}}</span>{{#if assignedGambit}}<span class="die-tag">{{assignedGambit.label}}</span>{{/if}}</span>
      <span class="die-tag">{{@root.weapon.die}}</span>
    </span>
    {{else}}
    <span
      class="die-result {{colorClass}} {{#if isGambitEligible}}gambit-eligible{{/if}} {{#if sacrificed}}sacrificed{{/if}}"
      data-index="{{index}}"
    >{{value}}{{#if assignedGambit}}<span class="die-tag">{{assignedGambit.label}}</span>{{/if}}</span>
    {{/if}}
    {{/each}}
    {{#if setupDie}}
    <span class="die-result die-setup {{setupDieColorClass}} {{#if usedSetupDie}}active{{else}}{{#if (eq phase "pending")}}pending{{else}}hidden{{/if}}{{/if}}">
      {{setupDie.value}}<span class="die-tag">SETUP</span>
    </span>
    {{/if}}
  </div>

  {{#if isCombat}}
  <div class="outcome-line">Highest: {{highest}}</div>
  {{else if isDefense}}
  <div class="outcome-line {{outcomeClass}}">{{defenseResult}}</div>
  {{else}}
  <div class="outcome-line {{outcomeClass}}">Highest: {{highest}} &mdash; {{outcome}}</div>
  {{/if}}

  {{!-- ===== PENDING: Setup Die Toggle (all roll types) ===== --}}
  {{#if (eq phase "pending")}}
  {{#if setupDie}}
  <div class="setup-die-row">
    <button type="button" class="setup-die-toggle">
      Use Setup Die <strong>{{setupDie.value}}</strong> from {{setupDie.source}}
    </button>
  </div>
  {{/if}}

  {{!-- Stakes — Simple Toggle --}}
  {{#if isStakes}}
  <div class="gambit-controls">
    {{#if hasGambitDice}}<p class="gambit-hint">Click dice showing 4+ to sacrifice for narrative leverage.</p>{{/if}}
    <div class="gambit-buttons">
      <button type="button" class="gambit-confirm-btn">Confirm</button>
      <button type="button" class="gambit-skip-btn">Skip</button>
    </div>
  </div>
  {{/if}}

  {{!-- Combat/Defense — Gambit Panel --}}
  {{#if showGambitPanel}}
  <div class="gambit-controls">
    {{#if hasGambitDice}}<p class="gambit-hint">Click a die (4+) to select it, then choose a gambit below.</p>{{/if}}
    <div class="gambit-panel" hidden>
      <div class="gambit-list">
        {{!-- Populated dynamically by JS --}}
      </div>
    </div>
    <div class="gambit-buttons">
      <button type="button" class="gambit-confirm-btn">Confirm Gambits</button>
      <button type="button" class="gambit-skip-btn">Skip</button>
    </div>
  </div>
  {{/if}}
  {{/if}}

  {{!-- ===== RESOLVED ===== --}}
  {{#if (eq phase "resolved")}}

  {{!-- Setup die note --}}
  {{#if usedSetupDie}}
  <div class="gambits-section setup-die-used">
    Setup die from <strong>{{setupDie.source}}</strong>
  </div>
  {{/if}}

  {{!-- Stakes: show sacrifice count --}}
  {{#if isStakes}}
  {{#if sacrificedCount}}
  <div class="gambits-section">
    <strong>Sacrificed {{sacrificedCount}} {{#if (eq sacrificedCount 1)}}die{{else}}dice{{/if}}</strong> for narrative leverage
  </div>
  {{/if}}
  {{/if}}

  {{!-- Combat/Defense: show named gambits --}}
  {{#if hasGambits}}
  <div class="gambits-section">
    <strong>Gambits:</strong>
    {{#each gambits}}
    <div class="gambit-entry">
      <span class="gambit-entry-name">{{label}}</span>
      <span class="gambit-tier">{{tier}}</span>
      &mdash; {{desc}}
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if isCombat}}
  {{#if weaponDamage}}
  <div class="weapon-section">
    <strong>{{weapon.name}}</strong>
    {{#if weaponDamage.forfeited}}
    <span class="damage-forfeited">— no damage (all dice used)</span>
    {{else}}
    <button class="mondas-apply-damage" data-damage="{{weaponDamage.value}}" data-cover="{{coverArmor}}">
      Apply {{weaponDamage.value}} Damage
    </button>
    {{/if}}
  </div>
  {{/if}}
  {{/if}}

  {{/if}}
</div>
