{{!-- MONDAS Roll — Chat Card (pending / resolved) --}}
<div class="mondas-roll-chat" data-phase="{{phase}}">
  <div class="roll-header">
    <strong>{{statLabel}}</strong> &mdash; {{rollTypeLabel}}
  </div>

  <div class="pool-desc">{{poolDesc}} = {{poolLabel}}</div>

  <div class="dice-grid">
    {{#each dice}}
    <span
      class="die-result {{colorClass}} {{#if isGambitEligible}}gambit-eligible{{/if}} {{#if sacrificed}}sacrificed{{/if}}"
      data-index="{{index}}"
    >{{value}}{{#if assignedGambit}}<span class="die-gambit-label">{{assignedGambit.label}}</span>{{/if}}</span>
    {{/each}}
  </div>

  <div class="outcome-line {{outcomeClass}}">
    Highest: {{highest}} &mdash; {{outcome}}
  </div>

  {{!-- ===== PENDING: Stakes — Simple Toggle ===== --}}
  {{#if (eq phase "pending")}}
  {{#if isStakes}}
  <div class="gambit-controls">
    <p class="gambit-hint">Click dice showing 4+ to sacrifice for narrative leverage.</p>
    <div class="gambit-buttons">
      <button type="button" class="gambit-confirm-btn">Confirm</button>
      <button type="button" class="gambit-skip-btn">Skip</button>
    </div>
  </div>
  {{/if}}

  {{!-- ===== PENDING: Combat/Defense — Gambit Panel ===== --}}
  {{#if showGambitPanel}}
  <div class="gambit-controls">
    <p class="gambit-hint">Click a die (4+) to select it, then choose a gambit below.</p>
    <div class="gambit-panel" hidden>
      <div class="gambit-list">
        {{!-- Populated dynamically by JS --}}
      </div>
    </div>
    <div class="gambit-buttons">
      <button type="button" class="gambit-confirm-btn">Confirm Gambits</button>
      <button type="button" class="gambit-skip-btn">Skip</button>
    </div>
  </div>
  {{/if}}
  {{/if}}

  {{!-- ===== RESOLVED ===== --}}
  {{#if (eq phase "resolved")}}

  {{!-- Stakes: show sacrifice count --}}
  {{#if isStakes}}
  {{#if sacrificedCount}}
  <div class="gambits-section">
    <strong>Sacrificed {{sacrificedCount}} {{#if (eq sacrificedCount 1)}}die{{else}}dice{{/if}}</strong> for narrative leverage
  </div>
  {{/if}}
  {{/if}}

  {{!-- Combat/Defense: show named gambits --}}
  {{#if hasGambits}}
  <div class="gambits-section">
    <strong>Gambits:</strong>
    {{#each gambits}}
    <div class="gambit-entry">
      <span class="gambit-entry-name">{{label}}</span>
      <span class="gambit-tier">{{tier}}</span>
      &mdash; {{desc}}
    </div>
    {{/each}}
  </div>
  {{/if}}

  {{#if isCombat}}
  {{#if weapon}}
  <div class="weapon-section">
    <strong>{{weapon.name}}</strong> ({{weapon.die}}): <span class="weapon-damage">{{weapon.damage}}</span>
    <button class="mondas-apply-damage" data-damage="{{weapon.damage}}">
      Apply {{weapon.damage}} Damage
    </button>
  </div>
  {{/if}}
  {{/if}}

  {{/if}}
</div>
