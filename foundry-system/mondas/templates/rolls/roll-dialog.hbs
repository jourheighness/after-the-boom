{{!-- MONDAS Roll Dialog — single template, two phases --}}

{{#if (eq phase "config")}}
{{!-- ===== PHASE 1: Pool Builder ===== --}}
<div class="roll-config">
  <div class="stat-header">
    <span class="stat-name">{{statLabel}}</span>
    <span class="stat-base">Base pool: {{statValue}}</span>
  </div>

  {{!-- Roll Type --}}
  <fieldset class="roll-type-group">
    <legend>Roll Type</legend>
    <label>
      <input type="radio" name="rollType" value="stakes" {{checked (eq rollType "stakes")}} />
      Stakes Roll
    </label>
    <label>
      <input type="radio" name="rollType" value="combat" {{checked (eq rollType "combat")}} />
      Combat Roll
    </label>
  </fieldset>

  {{!-- Boons --}}
  <div class="modifier-row">
    <span class="modifier-label">Boons</span>
    <button type="button" data-action="adjustBoons" data-delta="-1">-</button>
    <span class="modifier-value">{{boons}}</span>
    <button type="button" data-action="adjustBoons" data-delta="1">+</button>
  </div>

  {{!-- Snags --}}
  <div class="modifier-row">
    <span class="modifier-label">Snags</span>
    <button type="button" data-action="adjustSnags" data-delta="-1">-</button>
    <span class="modifier-value">{{snags}}</span>
    <button type="button" data-action="adjustSnags" data-delta="1">+</button>
  </div>

  {{!-- Spend Drain --}}
  <div class="modifier-row">
    <label class="drain-toggle">
      <input type="checkbox" name="spendDrain" {{checked spendDrain}} {{#unless drainAvailable}}disabled{{/unless}} />
      Spend Drain (+1d)
    </label>
    {{#unless drainAvailable}}<span class="drain-empty">No drain available</span>{{/unless}}
  </div>

  {{!-- Weapon Selector (combat only) --}}
  {{#if weapons.length}}
  <div class="weapon-selector">
    <label>Weapon</label>
    <select name="selectedWeapon">
      {{#each weapons}}
      <option value="{{@index}}" {{#if (eq @index ../selectedWeaponIndex)}}selected{{/if}}>
        {{this.name}} ({{this.die}})
      </option>
      {{/each}}
    </select>
  </div>
  {{/if}}

  {{!-- Pool Preview --}}
  <div class="pool-preview">
    Rolling <strong>{{poolLabel}}</strong>
  </div>

  {{!-- Roll Button --}}
  <button type="button" class="roll-btn" data-action="executeRoll">Roll</button>
</div>

{{else}}
{{!-- ===== PHASE 2: Gambit Selection ===== --}}
<div class="gambit-phase">
  <div class="roll-outcome">
    <h3>Your Roll</h3>
    <div class="outcome-line {{outcomeClass}}">
      Highest: {{highestDie}} &mdash; {{outcome}}
    </div>
  </div>

  <div class="dice-grid">
    {{#each dice}}
    <div
      class="die-result {{colorClass}} {{#if isGambitEligible}}gambit-eligible{{/if}} {{#if isSacrificed}}sacrificed{{/if}}"
      {{#if isGambitEligible}}data-action="toggleDie" data-index="{{index}}"{{/if}}
    >
      {{value}}
    </div>
    {{/each}}
  </div>

  {{#if hasGambitDice}}
  <p class="gambit-hint">Click dice showing 4+ to sacrifice them as gambits.</p>

  <div class="gambit-input">
    <label>Describe your gambit:</label>
    <input type="text" name="gambitText" placeholder="e.g. pushed him into cover" />
  </div>
  {{/if}}

  <div class="gambit-buttons">
    <button type="button" class="roll-btn" data-action="confirmGambits">Confirm Gambits</button>
    <button type="button" class="skip-btn" data-action="skipGambits">Skip</button>
  </div>
</div>
{{/if}}
