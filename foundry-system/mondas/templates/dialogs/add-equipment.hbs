{{!-- MONDAS — Add Equipment Dialog --}}
<form class="mondas add-equipment-form">
  <div class="form-group">
    <label>Name</label>
    <input type="text" name="name" placeholder="What is it?" autofocus>
  </div>

  <div class="form-group">
    <label>Description</label>
    <input type="text" name="description" placeholder="One line, what it does">
  </div>

  <div class="form-group">
    <label>Quantity</label>
    <input type="number" name="quantity" value="1" min="0">
  </div>

  <div class="form-group">
    <label>Tags</label>
    <div class="tag-toggles">
      {{#each tags}}
      <label class="tag-toggle">
        <input type="checkbox" name="tag" value="{{this}}">
        <span>{{this}}</span>
      </label>
      {{/each}}
    </div>
  </div>

  <fieldset class="thaumatech-gambit-section">
    <legend>Thaumatech Gambit (optional)</legend>
    <div class="form-group">
      <label>Gambit Name</label>
      <input type="text" name="gambitName" placeholder="Name of the device gambit">
    </div>
    <div class="form-group">
      <label>Gambit Effect</label>
      <input type="text" name="gambitDesc" placeholder="What it does when used">
    </div>
  </fieldset>
</form>
