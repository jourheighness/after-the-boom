{{!-- MONDAS — Add/Edit Edge Dialog --}}
<div class="mondas-dialog add-edge-form">
  <div class="form-group">
    <label>Name</label>
    <input type="text" name="name" value="{{name}}" placeholder="Edge name" autofocus>
  </div>

  <div class="form-group">
    <label>Mechanical Effect</label>
    <input type="text" name="mechanical" value="{{mechanical}}" placeholder="What it does mechanically">
  </div>

  <fieldset class="thaumatech-gambit-section">
    <legend>Gambit (optional)</legend>
    <div class="form-group">
      <label>Gambit Name</label>
      <input type="text" name="gambitName" value="{{gambitName}}" placeholder="Name of the gambit">
    </div>
    <div class="form-group">
      <label>Gambit Effect</label>
      <input type="text" name="gambitDesc" value="{{gambitDesc}}" placeholder="What it does when used">
    </div>
  </fieldset>
</div>
